      <table name="user_progress" numRows="0" remarks="" schema="public" type="VIEW" viewSql=" WITH daily_sums AS (&#10;         SELECT challenge_entries.user_challenge_id,&#10;            challenge_entries.entry_date,&#10;            sum(challenge_entries.amount) AS total_amount,&#10;            bool_or(challenge_entries.is_completed) AS is_done&#10;           FROM challenge_entries&#10;          GROUP BY challenge_entries.user_challenge_id, challenge_entries.entry_date&#10;        ), successful_days AS (&#10;         SELECT ds.user_challenge_id,&#10;            count(*) AS success_count&#10;           FROM ((daily_sums ds&#10;             JOIN user_challenges uc_1 ON ((ds.user_challenge_id = uc_1.id)))&#10;             JOIN challenges c ON ((uc_1.challenge_id = c.id)))&#10;          WHERE ((((c.entry_type)::text = 'amount'::text) AND (ds.total_amount &gt;= c.daily_target)) OR (((c.entry_type)::text = 'checkbox'::text) AND ds.is_done))&#10;          GROUP BY ds.user_challenge_id&#10;        )&#10; SELECT uc.id AS user_challenge_id,&#10;    uc.user_id,&#10;    uc.challenge_id,&#10;    COALESCE(sd.success_count, (0)::bigint) AS successful_days,&#10;    LEAST(round((((COALESCE(sd.success_count, (0)::bigint))::numeric / 7.0) * (100)::numeric)), (100)::numeric) AS progress&#10;   FROM (user_challenges uc&#10;     LEFT JOIN successful_days sd ON ((uc.id = sd.user_challenge_id)));">
         <column autoUpdated="false" defaultValue="null" digits="0" id="0" name="user_challenge_id" nullable="true" remarks="" size="10" type="int4" typeCode="4"/>
