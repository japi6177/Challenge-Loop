<div class="row w-100 justify-content-center mt-5">
  <div class="col-md-8 col-lg-6">
    <div class="glass-card p-5">
      <h2 class="fw-bold mb-4 text-center">Create a Custom Challenge</h2>
      <p class="text-white-50 text-center mb-4">Design your own weekly challenge and add it to the loop.</p>

      {{#if error}}
      <div class="alert alert-danger" role="alert">
        {{error}}
      </div>
      {{/if}}

      <form action="/create-challenge" method="POST">
        
        <div class="mb-3">
          <label class="form-label text-white-50 small text-uppercase fw-bold">Category</label>
          <select class="form-control bg-dark text-white border-secondary" name="category_id" required>
            <option value="">Select a category</option>
            {{#each categories}}
            <option value="{{this.id}}">{{this.name}}</option>
            {{/each}}
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label text-white-50 small text-uppercase fw-bold">Title</label>
          <input type="text" class="form-control" name="title" required placeholder="Challenge title">
        </div>

        <div class="mb-3">
          <label class="form-label text-white-50 small text-uppercase fw-bold">Description</label>
          <textarea class="form-control" name="description" rows="3" placeholder="Describe the challenge"></textarea>
        </div>

        <div class="mb-3">
          <label class="form-label text-white-50 small text-uppercase fw-bold">Entry Type</label>
          <select class="form-control bg-dark text-white border-secondary" name="entry_type" required>
            <option value="checkbox">Checkbox</option>
            <option value="amount">Amount</option>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label text-white-50 small text-uppercase fw-bold">Daily Target</label>
          <input type="number" step="0.01" class="form-control" name="daily_target" value="1" required>
        </div>

        <div class="mb-3">
          <label class="form-label text-white-50 small text-uppercase fw-bold">Start Date</label>
          <input type="date" class="form-control" name="start_date" value="{{today}}" required>
        </div>

        <div class="mb-4">
          <label class="form-label text-white-50 small text-uppercase fw-bold">End Date</label>
          <input type="date" class="form-control" name="end_date" required>
        </div>

        <button type="submit" class="btn btn-neon w-100">Create Challenge</button>
      </form>

      <div class="text-center mt-4">
        <a href="/home" class="text-white-50 text-decoration-none">Cancel</a>
      </div>
    </div>
  </div>
</div>

<style>
  select, option {
    background-color: #111 !important;
    color: white !important;
  }
</style>