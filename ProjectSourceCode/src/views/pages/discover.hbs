<div class="row w-100 mt-2 px-md-4 align-items-start">
  <div class="col-12 mb-4 text-center">
    <h1 class="display-5 fw-bold"><i class="fa-solid fa-compass me-2" style="color: var(--primary);"></i>Discover Challenges</h1>
    <p class="text-white-50">Pick your categories, browse popular ones, and start dominating.</p>
  </div>
  
  <div class="col-md-4 mb-4">
    <div class="glass-card p-4">
      <h4 class="fw-bold mb-3">Your Preferences</h4>
      <form action="/update-preferences" method="POST">
        <label class="form-label text-white-50 small text-uppercase">Categories you enjoy:</label>
        <div class="d-flex flex-column gap-2 mb-4 mt-2">
          {{#each allCategories}}
          <div class="form-check">
            <input class="form-check-input" type="checkbox" value="{{this}}" id="cat_{{this}}" name="categories">
            <label class="form-check-label fw-semibold" for="cat_{{this}}">
              {{this}}
            </label>
          </div>
          {{/each}}
        </div>
        <button type="submit" class="btn btn-sm btn-outline-light w-100 rounded-pill">Save Preferences</button>
      </form>

      <hr class="border-secondary opacity-25 my-4">

      <h5 class="fw-bold mb-3"><i class="fa-solid fa-fire me-2" style="color: var(--secondary);"></i>Global Popularity</h5>
      <ul class="list-group list-group-flush bg-transparent">
        {{#each allCategories}}
        <li class="list-group-item bg-transparent text-white border-secondary border-opacity-25 px-0 d-flex justify-content-between align-items-center">
            {{this}}
            <i class="fa-solid fa-arrow-trend-up text-white-50"></i>
        </li>
        {{/each}}
      </ul>
    </div>
  </div>

  <div class="col-md-8">
    <div class="glass-card p-4 mb-4" style="background: rgba(202, 255, 0, 0.03); border-color: rgba(202, 255, 0, 0.2);">
      <h4 class="fw-bold mb-3 text-white">Recommended For You</h4>
      <div class="row row-cols-1 row-cols-md-2 g-3">
        {{#each recommended}}
        <div class="col">
          <div class="card bg-dark border-0 h-100 rounded-4" style="background: rgba(0,0,0,0.4) !important; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05);">
            <div class="card-body">
              <span class="badge mb-2 px-2 py-1" style="background: var(--secondary);">{{this.category}}</span>
              <h5 class="card-title fw-bold text-white">{{this.title}}</h5>
              <p class="card-text text-white-50 small">{{this.description}}</p>
              <form action="/join-challenge" method="POST">
                <input type="hidden" name="challenge_id" value="{{this.id}}">
                <button type="submit" class="btn btn-sm btn-neon mt-2 w-100" style="font-size: 0.8rem;">Join Challenge <i class="fa-solid fa-plus ms-1"></i></button>
              </form>
            </div>
          </div>
        </div>
        {{else}}
          <div class="col-12"><p class="text-white-50">No new recommendations right now. Try updating your preferences!</p></div>
        {{/each}}
      </div>
    </div>

    {{#if completed.length}}
    <div class="glass-card p-4">
      <h4 class="fw-bold mb-3 text-white-50 fs-5"><i class="fa-solid fa-medal me-2" style="color: var(--primary);"></i>Conquered Challenges</h4>
      <div class="d-flex flex-wrap gap-2">
        {{#each completed}}
         <span class="badge border border-secondary text-secondary p-2 rounded-pill"><i class="fa-solid fa-check me-1"></i>{{this.title}}</span>
        {{/each}}
      </div>
    </div>
    {{/if}}
  </div>
</div>
