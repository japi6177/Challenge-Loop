<div class="row w-100 mt-2 align-items-start justify-content-center">
  <div class="col-md-6 text-center text-md-start mb-5 mb-md-0 px-md-5">
    <h1 class="display-3 fw-bolder mb-3" style="letter-spacing:-1px;">Hello, <span style="color: var(--primary);">{{user.username}}</span>!</h1>
    <p class="lead text-white-50 mb-4" style="line-height: 1.6;">Welcome to your dashboard. This is where your challenge loop begins. Setup your routines and push your limits over the edge.</p>
    <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-md-start">
      <a href="/discover" class="btn btn-neon">Browse Challenges</a>
      <button class="btn rounded-pill px-4" style="border: 1px solid rgba(255,255,255,0.2); color:white;">Profile Details</button>
    </div>

    <div class="mt-5 pt-3 text-start">
      <h3 class="fw-bold mb-3"><i class="fa-solid fa-list-check me-2" style="color: var(--primary);"></i>Active Challenges</h3>
      {{#if active.length}}
        <div class="d-flex flex-column gap-3">
          {{#each active}}
          <div class="p-4 rounded-4" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); transition: transform 0.2s;">
             <div class="d-flex justify-content-between align-items-center mb-2">
               <h5 class="fw-bold m-0 text-white">{{this.title}}</h5>
               <span class="badge" style="background: var(--secondary);">{{this.category}}</span>
             </div>
             <p class="text-white-50 small mb-3">{{this.description}}</p>
             <div class="progress mb-2" style="height: 8px; background: rgba(0,0,0,0.5); border-radius: 10px;">
                <div class="progress-bar" role="progressbar" style="width: {{this.progress}}%; background: var(--primary);" aria-valuenow="{{this.progress}}" aria-valuemin="0" aria-valuemax="100"></div>
             </div>
             <div class="d-flex justify-content-between align-items-center mt-3 border-top pt-3" style="border-color: rgba(255,255,255,0.05) !important;">
               <small class="text-white-50"><i class="fa-regular fa-calendar me-1"></i>Ends: {{this.end_date}}</small>
               <span class="fw-bold badge bg-dark text-white border border-light border-opacity-25">{{this.progress}}% Complete</span>
             </div>
          </div>
          {{/each}}
        </div>
      {{else}}
        <div class="p-5 rounded-4 text-center mt-3" style="background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.15);">
          <i class="fa-solid fa-ghost fs-1 mb-3 text-white-50 opacity-50"></i>
          <p class="text-white-50 m-0">You don't have any active challenges yet.</p>
          <a href="/discover" class="fw-bold mt-3 d-inline-block text-decoration-none" style="color: var(--primary);">Find one now <i class="fa-solid fa-arrow-right ms-1"></i></a>
        </div>
      {{/if}}
    </div>
  </div>
  
  <div class="col-md-5 pt-3">
    <div class="glass-card text-center text-md-start p-5 position-relative overflow-hidden sticky-top" style="top: 2rem;">
      <div style="position:absolute; top:-50px; right:-50px; width:150px; height:150px; background:var(--primary); opacity:0.1; filter:blur(40px);"></div>
      <div class="d-flex align-items-center justify-content-center justify-content-md-start gap-3 mb-4">
        <div class="p-3 rounded-circle" style="background: rgba(144, 0, 255, 0.1);">
          <i class="fa-solid fa-trophy fs-3" style="color: var(--secondary);"></i>
        </div>
        <h3 class="fw-bold m-0 fs-2">Your Stats</h3>
      </div>
      
      <p class="text-white-50 mb-4">Track your metrics and watch them grow daily. Consistency is the key to mastering the loop.</p>
      
      <div class="row mt-4 pt-3 border-top" style="border-color: rgba(255,255,255,0.05) !important;">
        <div class="col-6 border-end" style="border-color: rgba(255,255,255,0.05) !important;">
          <h2 class="fw-bold mb-1 lh-1" style="color: var(--primary); font-size: 3rem;">{{activeCount}}</h2>
          <small class="text-uppercase text-white-50 fw-bold" style="font-size: 0.75rem; letter-spacing:1px;">Active</small>
        </div>
        <div class="col-6 px-4">
          <h2 class="fw-bold mb-1 lh-1" style="color: var(--primary); font-size: 3rem;">{{completedCount}}</h2>
          <small class="text-uppercase text-white-50 fw-bold" style="font-size: 0.75rem; letter-spacing:1px;">Completed</small>
        </div>
      </div>
    </div>
  </div>
</div>
