<div class="row w-100 mt-2 align-items-start justify-content-center">
  <div class="col-md-6 text-center text-md-start mb-5 mb-md-0 px-md-5">
    <h1 class="display-3 fw-bolder mb-3" style="letter-spacing:-1px;">Hello, <span style="color: var(--primary);">{{user.username}}</span>!</h1>
    <p class="lead text-white-50 mb-4" style="line-height: 1.6;">Welcome to your dashboard. This is where your challenge loop begins. Setup your routines and push your limits over the edge.</p>
    <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-md-start">
      <a href="/discover" class="btn btn-neon">Browse Challenges</a>
      <a href="/create-challenge" class="btn rounded-pill px-4 text-decoration-none" style="border: 1px solid rgba(255,255,255,0.2); color:white;">Create Challenge</a>
      <a href="/profile" class="btn rounded-pill px-4 text-decoration-none" style="border: 1px solid rgba(255,255,255,0.2); color:white;">Profile Details</a>
    </div>

    <!-- Reminder Banners -->
    {{#if reminders}}
    <div class="mt-4 d-flex flex-column gap-2">
      {{#each reminders}}
      {{#if (eq this.level '1h')}}
      <div class="d-flex align-items-center gap-3 p-3 rounded-4 reminder-pulse" style="background: rgba(255, 59, 59, 0.12); border: 1px solid rgba(255,59,59,0.5);">
        <i class="fa-solid fa-bell fs-4" style="color: #ff3b3b;"></i>
        <div>
          <div class="fw-bold" style="color:#ff6b6b;">Final Hour! <a href="/challenge/{{this.id}}" class="text-decoration-none" style="color:#ff9999;">{{this.title}}</a></div>
          <small class="text-white-50">Less than 1 hour left — give it everything you've got!</small>
        </div>
      </div>
      {{else if (eq this.level '12h')}}
      <div class="d-flex align-items-center gap-3 p-3 rounded-4" style="background: rgba(255, 165, 0, 0.1); border: 1px solid rgba(255,165,0,0.4);">
        <i class="fa-solid fa-hourglass-half fs-4" style="color: #ffaa00;"></i>
        <div>
          <div class="fw-bold" style="color:#ffcc55;">12 Hours Left! <a href="/challenge/{{this.id}}" class="text-decoration-none" style="color:#ffe08a;">{{this.title}}</a></div>
          <small class="text-white-50">Don't miss your chance to log progress before it ends.</small>
        </div>
      </div>
      {{else}}
      <div class="d-flex align-items-center gap-3 p-3 rounded-4" style="background: rgba(202,255,0,0.06); border: 1px solid rgba(202,255,0,0.3);">
        <i class="fa-solid fa-clock fs-4" style="color: var(--primary);"></i>
        <div>
          <div class="fw-bold" style="color: var(--primary);">24 Hours Left! <a href="/challenge/{{this.id}}" class="text-decoration-none" style="color:var(--primary);">{{this.title}}</a></div>
          <small class="text-white-50">One day to go — keep the streak alive.</small>
        </div>
      </div>
      {{/if}}
      {{/each}}
    </div>
    {{/if}}

    <div class="mt-5 pt-3 text-start">
      <h3 class="fw-bold mb-3"><i class="fa-solid fa-list-check me-2" style="color: var(--primary);"></i>Active Challenges</h3>
      {{#if active.length}}
        <div class="d-flex flex-column gap-3">
          {{#each active}}
          <div class="p-4 rounded-4 {{#if (eq this.reminder_level '1h')}}reminder-pulse{{/if}}" style="background: rgba(255,255,255,0.03); border: 1px solid {{#if (eq this.reminder_level '1h')}}rgba(255,59,59,0.4){{else if (eq this.reminder_level '12h')}}rgba(255,165,0,0.3){{else if (eq this.reminder_level '24h')}}rgba(202,255,0,0.2){{else}}rgba(255,255,255,0.08){{/if}}; transition: transform 0.2s;">
             <div class="d-flex justify-content-between align-items-center mb-2">
               <a href="/challenge/{{this.id}}" class="fw-bold m-0 text-white text-decoration-none fs-5">{{this.title}} <i class="fa-solid fa-arrow-right-long opacity-50 ms-1 small"></i></a>
               <div class="d-flex gap-2 align-items-center">
                 <span class="badge rounded-pill px-2 py-1" style="background: rgba(255,255,255,0.07); font-size:0.7rem; color:white;">
                   <i class="fa-solid {{iconForType this.challenge_type}} me-1" style="color: var(--primary);"></i>{{labelForType this.challenge_type}}
                 </span>
                 <span class="badge" style="background: var(--secondary);">{{this.category}}</span>
               </div>
             </div>
             <p class="text-white-50 small mb-3">{{this.description}}</p>
             <div class="progress mb-2" style="height: 8px; background: rgba(0,0,0,0.5); border-radius: 10px;">
                <div class="progress-bar" role="progressbar" style="width: {{this.progress}}%; background: var(--primary);" aria-valuenow="{{this.progress}}" aria-valuemin="0" aria-valuemax="100"></div>
             </div>

             <!-- Countdown Timer (shown when < 24h remaining) -->
             {{#if this.show_countdown}}
             <div class="d-flex align-items-center gap-2 mb-3 p-2 rounded-3" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(202,255,0,0.15);">
               <i class="fa-solid fa-stopwatch" style="color: var(--primary);"></i>
               <span class="text-white-50 small fw-bold text-uppercase" style="letter-spacing:1px; font-size:0.65rem;">Time Left</span>
               <span class="countdown fw-bold ms-1" style="color: var(--primary); font-variant-numeric: tabular-nums; font-size:0.9rem;" data-end="{{this.end_timestamp}}">--:--:--</span>
             </div>
             {{/if}}

             <!-- Inline Data Entry -->
             <div class="mt-3 mb-2 bg-dark p-2 rounded" style="background: rgba(0,0,0,0.2) !important;">
                <form action="/challenge/{{this.id}}/log" method="POST" class="d-flex align-items-center justify-content-between gap-2">
                   <input type="hidden" name="date" value="{{../today}}">
                   <small class="text-white-50"><i class="fa-solid fa-bolt me-1 text-warning"></i> Quick Log:</small>
                   <div class="d-flex gap-2">
                     {{#if (eq this.entry_type 'amount')}}
                       <input type="number" step="0.01" style="width: 80px;" class="form-control form-control-sm bg-transparent text-white border-secondary" name="amount" placeholder="Amt" required>
                       <button class="btn btn-sm btn-neon pb-1 pt-1"><i class="fa-solid fa-check"></i></button>
                     {{else}}
                       <input type="hidden" name="completed" value="on">
                       <button class="btn btn-sm btn-outline-light pb-1 pt-1" style="border-color: var(--primary); color: white;"><i class="fa-solid fa-check me-1"></i> Done</button>
                     {{/if}}
                   </div>
                </form>
             </div>

             <div class="d-flex justify-content-between align-items-center mt-3 border-top pt-3" style="border-color: rgba(255,255,255,0.05) !important;">
               <small class="text-white-50"><i class="fa-regular fa-calendar me-1"></i>Ends: <span class="local-date text-white" data-date="{{this.end_date}}"></span></small>
               <span class="fw-bold badge bg-dark text-white border border-light border-opacity-25">{{this.progress}}% Complete</span>
             </div>
          </div>
          {{/each}}
        </div>
      {{else}}
        <div class="p-5 rounded-4 text-center mt-3" style="background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.15);">
          <i class="fa-solid fa-ghost fs-1 mb-3 text-white-50 opacity-50"></i>
          <p class="text-white-50 m-0">You don't have any active challenges yet.</p>
          <a href="/discover" class="fw-bold mt-3 d-inline-block text-decoration-none" style="color: var(--primary);">Find one now <i class="fa-solid fa-arrow-right ms-1"></i></a>
        </div>
      {{/if}}
    </div>
  </div>

  <div class="col-md-5 pt-3">
    <div class="glass-card text-center text-md-start p-5 position-relative overflow-hidden sticky-top" style="top: 2rem;">
      <div style="position:absolute; top:-50px; right:-50px; width:150px; height:150px; background:var(--primary); opacity:0.1; filter:blur(40px);"></div>
      <div class="d-flex align-items-center justify-content-center justify-content-md-start gap-3 mb-4">
        <div class="p-3 rounded-circle" style="background: rgba(144, 0, 255, 0.1);">
          <i class="fa-solid fa-trophy fs-3" style="color: var(--secondary);"></i>
        </div>
        <h3 class="fw-bold m-0 fs-2">Your Stats</h3>
      </div>

      <p class="text-white-50 mb-4">Track your metrics and watch them grow daily. Consistency is the key to mastering the loop.</p>

      <div class="row mt-4 pt-3 border-top" style="border-color: rgba(255,255,255,0.05) !important;">
        <div class="col-6 border-end" style="border-color: rgba(255,255,255,0.05) !important;">
          <h2 class="fw-bold mb-1 lh-1" style="color: var(--primary); font-size: 3rem;">{{activeCount}}</h2>
          <small class="text-uppercase text-white-50 fw-bold" style="font-size: 0.75rem; letter-spacing:1px;">Active</small>
        </div>
        <div class="col-6 px-4">
          <h2 class="fw-bold mb-1 lh-1" style="color: var(--primary); font-size: 3rem;">{{completedCount}}</h2>
          <small class="text-uppercase text-white-50 fw-bold" style="font-size: 0.75rem; letter-spacing:1px;">Completed</small>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
@keyframes reminderPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255,59,59,0); }
  50% { box-shadow: 0 0 12px 4px rgba(255,59,59,0.25); }
}
.reminder-pulse { animation: reminderPulse 2s ease-in-out infinite; }
</style>
