<div class="row w-100 mt-4 align-items-stretch justify-content-center g-4 px-md-4">
  <div class="col-12 text-center mb-2">
    <h1 class="display-3 fw-bolder mb-2" style="letter-spacing:-1px;">Enter the <span style="color: var(--primary);">Loop</span></h1>
    <p class="text-white-50 lead">Sign in with an email code, or begin a new journey today.</p>
  </div>

  <!-- Login Section -->
  <div class="col-12 col-md-8 col-lg-6 d-flex">
    <div class="glass-card w-100 p-4 p-md-5 d-flex flex-column" style="background: rgba(144, 0, 255, 0.02); border-color: rgba(144, 0, 255, 0.1);">
      <div class="text-center mb-4">
        <h2 class="fw-bold fs-2 text-white">Welcome</h2>
        <p class="text-white-50 small">Enter your email securely to log in or create an account.</p>
      </div>
      
      {{#if loginError}}
      <div class="alert alert-danger" style="background: rgba(220, 53, 69, 0.1); border-color: rgba(220, 53, 69, 0.4); color: #ff6b81;" role="alert">
        <i class="fa-solid fa-circle-exclamation me-2"></i>{{loginError}}
      </div>
      {{/if}}

      <form action="/email-login" method="POST" class="mb-auto mt-4">
        <div class="mb-5">
          <label class="form-label text-white-50 small text-uppercase fw-bold">Email Address</label>
          <input type="email" class="form-control form-control-lg" name="email" required placeholder="Enter your email address">
        </div>
        <button type="submit" class="btn btn-outline-info w-100 py-3 fw-bold shadow-sm" style="transition: all 0.2s ease;">Continue <i class="fa-solid fa-arrow-right ms-1"></i></button>
      </form>
    </div>
  </div>
</div>
