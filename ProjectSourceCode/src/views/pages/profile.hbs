<div class="container mt-5">
  <div class="row">

    <!-- SIDEBAR -->
    <div class="col-md-4 col-lg-3 mb-4">
      <div class="glass-card p-4 text-center">

        <!-- Profile Picture -->
        <div class="mb-3">
          {{#if profileUser.profile_picture}}
          <img src="{{profileUser.profile_picture}}" class="rounded-circle"
            style="width:90px; height:90px; object-fit:cover; border:3px solid var(--primary);">
          {{else}}
          <i class="fa-solid fa-user-astronaut fs-2 p-3 rounded-circle"
            style="background: rgba(255,255,255,0.05); color: var(--primary);"></i>
          {{/if}}
        </div>

        <h5 class="fw-bold mb-1">{{profileUser.username}}</h5>

        <!-- STATS -->
        <div class="d-flex justify-content-around mt-4 mb-3">
          <div>
            <div class="fw-bold" style="color: var(--primary);">{{activeCount}}</div>
            <small class="text-white-50">Active</small>
          </div>
          <div>
            <div class="fw-bold" style="color: var(--primary);">{{completedCount}}</div>
            <small class="text-white-50">Done</small>
          </div>
        </div>

        <!-- ACTIONS -->
        {{#if isMe}}
        <button class="btn btn-outline-light rounded-pill w-100 mb-2" data-bs-toggle="collapse"
          data-bs-target="#editPanel">
          Edit Profile
        </button>

        <a href="/logout" class="btn btn-sm text-danger">Sign out</a>

        {{else}}
        <div class="d-grid gap-2 mt-3">
          {{#if canAddFriend}}
          <form method="POST" action="/add-friend/{{profileUser.username}}">
            <button type="submit" class="btn btn-neon rounded-pill w-100">
              <i class="fa-solid fa-user-plus me-2"></i>Add Friend
            </button>
          </form>

          {{else if isPending}}
          <form method="POST" action="/add-friend/{{profileUser.username}}">
            <button type="submit" class="btn btn-neon rounded-pill w-100">
              <i class="fa-solid fa-user-plus me-2"></i>Cancel Request
            </button>
          </form>

          {{else if isIncoming}}
          <form method="POST" action="/add-friend/{{profileUser.username}}">
            <button type="submit" class="btn btn-neon rounded-pill w-100">
              <i class="fa-solid fa-user-check me-2"></i>Accept Friend Request
            </button>
          </form>

          {{else if isFriend}}
          <form method="POST" action="/add-friend/{{profileUser.username}}"
            onsubmit="return confirm('Remove this friend?');">
            <button type="submit" class="btn btn-outline-danger rounded-pill w-100">
              <i class="fa-solid fa-user-minus me-2"></i>Unfriend
            </button>
          </form>
          {{/if}}
        </div>
        {{/if}}

        <div class="mt-4 pt-3 border-top border-secondary border-opacity-25">
          <small class="text-white-50">
            Joined <span class="local-date" data-date="{{profileUser.created_at}}"></span>
          </small>
        </div>

        <div class="mt-4 pt-3 border-top border-secondary border-opacity-25 text-start">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="mb-0 fw-bold" style="color: var(--primary);">
              Friends
            </h6>
            <span class="badge rounded-pill" style="background: var(--secondary);">
              {{friendCount}}
            </span>
          </div>

          {{#if friendsList.length}}
          <div class="d-flex flex-column gap-2">
            {{#each friendsList}}
            <a href="/profile/{{this.username}}" class="text-decoration-none">
              <div class="d-flex align-items-center justify-content-between p-2 rounded-3"
                style="background: rgba(255,255,255,0.04);">

                <div class="d-flex align-items-center gap-2">
                  {{#if this.profile_picture}}
                  <img src="{{this.profile_picture}}" class="rounded-circle"
                    style="width:36px; height:36px; object-fit:cover;">
                  {{else}}
                  <i class="fa-solid fa-user-astronaut p-2 rounded-circle"
                    style="background: rgba(255,255,255,0.05); color: var(--primary);"></i>
                  {{/if}}

                  <div>
                    <div class="text-white fw-semibold">{{this.username}}</div>
                    {{#if this.mutual}}
                    <small style="color: var(--primary);">Mutual friend</small>
                    {{/if}}
                  </div>
                </div>

                {{#if this.mutual}}
                <i class="fa-solid fa-user-check" style="color: var(--primary);"></i>
                {{/if}}
              </div>
            </a>
            {{/each}}
          </div>
          {{else}}
          <p class="text-white-50 small mb-0">No friends yet.</p>
          {{/if}}
        </div>

      </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="col-md-8 col-lg-9">

      <!-- FLASH MESSAGES -->
      {{#if flashError}}
      <div class="alert text-center">{{flashError}}</div>
      {{/if}}

      {{#if flashSuccess}}
      <div class="alert text-center">{{flashSuccess}}</div>
      {{/if}}

      <!-- EDIT PANEL -->
      {{#if isMe}}
      <div class="collapse mt-4" id="editPanel">
        <div class="glass-card p-4">

          <!-- Profile Picture -->
          <div class="mb-4 pb-4 border-bottom border-secondary border-opacity-25">
            <h6 class="text-uppercase fw-bold mb-3"
              style="color: var(--primary); font-size: 0.75rem; letter-spacing: 1px;">
              <i class="fa-solid fa-image me-2"></i>Profile Picture
            </h6>
            <div class="text-center mb-3">
              <img id="imgPreview"
                src="{{#if profileUser.profile_picture}}{{profileUser.profile_picture}}{{else}}{{/if}}" alt=""
                class="rounded-circle mb-2 {{#unless profileUser.profile_picture}}d-none{{/unless}}"
                style="width:80px; height:80px; object-fit:cover; border:2px solid var(--primary);">
            </div>
            <form method="POST" action="/profile/upload-picture">
              <input type="hidden" name="image_data" id="imageData">
              <label class="form-label text-white-50 small">Choose an image (max 2MB)</label>
              <input type="file" id="fileInput" accept="image/jpeg,image/png,image/gif,image/webp"
                class="form-control mb-2" style="cursor:pointer;">
              <p id="fileError" class="text-danger small d-none">Image must be under 2MB.</p>
              <button type="submit" id="uploadBtn" class="btn btn-neon w-100 rounded-pill" disabled>
                Upload Picture
              </button>
            </form>
          </div>

          <!-- Change Email -->
          <div class="mb-4 pb-4 border-bottom border-secondary border-opacity-25">
            <h6 class="text-uppercase fw-bold mb-3"
              style="color: var(--primary); font-size: 0.75rem; letter-spacing: 1px;">
              <i class="fa-solid fa-envelope me-2"></i>Change Email
            </h6>
            <form method="POST" action="/profile/change-email">
              <input type="email" name="new_email" class="form-control mb-2" placeholder="New email address"
                value="{{profileUser.email}}" required>
              <button type="submit" class="btn btn-neon w-100 rounded-pill">Update Email</button>
            </form>
          </div>

          <!-- Delete Account -->
          <div class="mt-4 pt-4 border-top border-danger border-opacity-25">
            <h6 class="text-uppercase fw-bold mb-3" style="color: #ff6b81; font-size: 0.75rem; letter-spacing: 1px;">
              <i class="fa-solid fa-triangle-exclamation me-2"></i>Danger Zone
            </h6>
            <form method="POST" action="/profile/delete-account"
              onsubmit="return confirm('Are you absolutely sure you want to delete your account? This action cannot be undone.');">
              <button type="submit" class="btn btn-outline-danger w-100 rounded-pill">Delete Account</button>
            </form>
          </div>

        </div>
      </div>
      {{/if}}

      <!-- TABS -->
      <div class="glass-card p-3 mb-3">
        <ul class="nav nav-pills justify-content-center" id="challengeTabs">
          <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#activeTab">
              Active
            </button>
          </li>
          <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#completedTab">
              Completed
            </button>
          </li>
        </ul>
      </div>

      <!-- TAB CONTENT -->
      <div class="tab-content">

        <!-- ACTIVE -->
        <div class="tab-pane fade show active" id="activeTab">
          <div class="d-flex flex-column gap-3">
            {{#if activeChallenges.length}}
            {{#each activeChallenges}}
            <a href="/challenge/{{this.id}}" class="text-decoration-none">
              <div class="p-3 rounded-4 glass-card">
                <div class="d-flex justify-content-between mb-2">
                  <span class="fw-bold text-white">{{this.title}}</span>
                  <span class="badge" style="background: var(--secondary);">{{this.category}}</span>
                </div>

                <p class="text-white-50 small mb-2">{{this.description}}</p>

                <div class="progress mb-2" style="height: 8px;">
                  <div class="progress-bar" style="width: {{this.progress}}%; background: var(--primary);">
                  </div>
                </div>

                <small class="text-white-50">Ends: {{this.end_date}}</small>
              </div>
            </a>
            {{/each}}
            {{else}}
            <p class="text-white-50">No active challenges yet.</p>
            {{/if}}
          </div>
        </div>

        <!-- COMPLETED -->
        <div class="tab-pane fade" id="completedTab">
          <div class="d-flex flex-column gap-3">
            {{#if completedChallenges.length}}
            {{#each completedChallenges}}
            <a href="/challenge/{{this.id}}" class="text-decoration-none">
              <div class="p-3 rounded-4 glass-card">
                <div class="d-flex justify-content-between mb-2">
                  <span class="fw-bold text-white">{{this.title}}</span>
                  <span class="badge bg-success">Completed</span>
                </div>

                <p class="text-white-50 small mb-1">{{this.description}}</p>
                <small class="text-white-50">{{this.category}}</small>
              </div>
            </a>
            {{/each}}
            {{else}}
            <p class="text-white-50">No completed challenges yet.</p>
            {{/if}}
          </div>
        </div>

      </div>



    </div>
  </div>
</div>

<script>
  (function () {
    const fileInput = document.getElementById('fileInput');
    const imageData = document.getElementById('imageData');
    const imgPreview = document.getElementById('imgPreview');
    const uploadBtn = document.getElementById('uploadBtn');
    const fileError = document.getElementById('fileError');

    fileInput.addEventListener('change', function () {
      const file = this.files[0];
      if (!file) return;

      if (file.size > 2 * 1024 * 1024) {
        fileError.classList.remove('d-none');
        uploadBtn.disabled = true;
        imageData.value = '';
        return;
      }

      fileError.classList.add('d-none');

      const reader = new FileReader();
      reader.onload = function (e) {
        imageData.value = e.target.result;
        imgPreview.src = e.target.result;
        imgPreview.classList.remove('d-none');
        uploadBtn.disabled = false;
      };
      reader.readAsDataURL(file);
    });
  })();
</script>