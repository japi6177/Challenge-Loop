<div class="glass-card col-12 col-md-6 col-lg-4 w-100 mx-auto" style="max-width: 450px;">
  <div class="text-center mb-4">
    <h2 class="fw-bold fs-1">Almost There!</h2>
    <p class="text-white-50">It looks like you're new here. Pick a username to continue.</p>
  </div>
  
  {{#if registerError}}
  <div class="alert alert-danger" style="background: rgba(220, 53, 69, 0.1); border-color: rgba(220, 53, 69, 0.4); color: #ff6b81;" role="alert">
    <i class="fa-solid fa-circle-exclamation me-2"></i>{{registerError}}
  </div>
  {{/if}}

  <form action="/register" method="POST">
    <input type="hidden" name="email" value="{{email}}">
    <div class="mb-5">
      <label for="username" class="form-label text-white-50 small text-uppercase fw-bold">Username</label>
      <input type="text" id="username" class="form-control" name="username" required placeholder="Pick a username" autocomplete="username">
    </div>
    <button type="submit" class="btn btn-neon w-100 mt-2">Send Verification Code</button>
  </form>
  <div class="text-center mt-5">
    <small class="text-white-50">Not you? <a href="/login" class="fw-semibold" style="color: var(--primary); text-decoration: none;">Go back</a></small>
  </div>
</div>
