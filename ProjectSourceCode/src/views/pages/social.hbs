<div class="container mt-5">
  <div class="glass-card p-4">
    <h2 class="fw-bold mb-4 text-center" style="color: var(--primary);">
      People In Your Challenges
    </h2>

    {{#if error}}
      <div class="alert text-center">{{error}}</div>
    {{/if}}

    {{#if groupedChallenges.length}}
      <div class="row g-4">
        {{#each groupedChallenges}}
          <div class="col-lg-4 col-md-6">
              <a href="/challenge/{{this.id}}" class="text-decoration-none">
            <div class="glass-card p-4 h-100 d-flex flex-column">

              <h5 class="fw-bold mb-2" style="color: var(--primary);">
                {{this.title}}
              </h5>

              <p class="text-white-50 small mb-3">
                {{this.description}}
              </p>

              <div class="d-flex flex-column gap-2 mt-auto">
                {{#each this.users}}
                  <a href="/profile/{{this.username}}" class="text-decoration-none">
                    <div class="d-flex align-items-center gap-2 p-2 rounded-3"
                         style="background: rgba(255,255,255,0.04);">

                      {{#if this.profile_picture}}
                        <img src="{{this.profile_picture}}" class="rounded-circle"
                             style="width:36px; height:36px; object-fit:cover;">
                      {{else}}
                        <i class="fa-solid fa-user-astronaut p-2 rounded-circle"
                           style="background: rgba(255,255,255,0.05); color: var(--primary);"></i>
                      {{/if}}

                      <span class="text-white">{{this.username}}</span>
                    </div>
                  </a>
                {{/each}}
              </div>

            </div>
            </a>
          </div>
        {{/each}}
      </div>
    {{else}}
      <p class="text-white-50 text-center mb-0">
        You do not share any challenges with other users yet.
      </p>
    {{/if}}
  </div>
</div>