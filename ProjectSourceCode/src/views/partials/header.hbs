<header class="py-3 px-4 w-100 d-flex justify-content-between align-items-center"
  style="background: rgba(15, 15, 19, 0.8); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.05); z-index: 10;">
  <a href="/home" class="d-flex align-items-center gap-2 text-decoration-none">
    <i class="fa-solid fa-infinity fs-3" style="color: var(--primary);"></i>
    <span class="fs-4 fw-bold text-light" style="letter-spacing: -1px;">
      Challenge<span style="color: var(--primary)">Loop</span>
    </span>
  </a>
  <nav>
    <ul class="nav">
      {{#if user}}
      <li class="nav-item me-2"><a class="btn btn-neon btn-sm rounded-pill d-flex align-items-center gap-2"
          href="/create-challenge" style="font-size: 0.85rem;">
          <i class="fa-solid fa-plus"></i><span>Create</span></a></li>

      <li class="nav-item"><a class="nav-link text-light opacity-75" href="/home">Dashboard</a></li>
      <li class="nav-item"><a class="nav-link text-light opacity-75" href="/discover">Discover</a></li>
      <li class="nav-item"><a class="nav-link text-light opacity-75" href="/social">Social</a></li>

      <li class="nav-item"><a class="nav-link" href="/ai/recommend" style="color: var(--secondary); opacity: 0.9;"><i
            class="fa-solid fa-wand-magic-sparkles me-1"></i>AI</a></li>

      <li class="nav-item"><a class="nav-link text-light opacity-75 d-flex align-items-center gap-2" href="/profile">
          {{#if user.profile_picture}}
          <img src="{{user.profile_picture}}" class="rounded-circle" style="width:26px; height:26px; object-fit:cover;">
          {{else}}
          <i class="fa-solid fa-user-astronaut"></i>
          {{/if}}
          <span>Profile</span>
        </a>
      </li>

      <li class="nav-item"><a class="nav-link text-light opacity-75" href="/logout"><i
            class="fa-solid fa-right-from-bracket me-1"></i>Logout</a></li>
      {{else}}
      <li class="nav-item ms-2"><a class="btn btn-neon btn-sm py-2 px-4 rounded-pill" style="font-size: 0.85rem;"
          href="/login">Join Us</a></li>
      {{/if}}
    </ul>
  </nav>
</header>